pkgbase = wxextract
	pkgdesc = Extract WeChat 4.x conversations on Linux into compact LLM-ready text + interactive HTML report
	pkgver = 0.7.1
	pkgrel = 1
	url = https://github.com/boujuan/extract-wechat-messages-linux
	arch = any
	license = MIT
	makedepends = python-build
	makedepends = python-installer
	makedepends = python-wheel
	makedepends = python-hatchling
	depends = python>=3.12
	depends = python-pycryptodome
	depends = python-zstandard
	depends = python-tiktoken
	depends = python-rich
	depends = python-rich-argparse
	optdepends = sqlcipher: faster + WAL-correct decrypt (falls back to pure-Python AES otherwise)
	optdepends = wechat-bin: the AUR build of WeChat 4.x this tool targets (only needed to extract live data)
	optdepends = rsync: faster snapshot copy (usually already installed)
